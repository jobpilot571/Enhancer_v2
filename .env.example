# AI Provider order (comma-separated). System tries each in order until one succeeds.
AI_PROVIDER_ORDER=openai,groq,claude,gemini,ollama

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# Groq (OpenAI-compatible)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (cloud/turbo key, OpenAI-compatible)
OLLAMA_API_KEY=your_ollama_key_here
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gpt-oss:20b

PORT=3001

# Admin console (you only) — required to sign in at /admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Optional: separate signing secret for admin tokens (defaults to ADMIN_PASSWORD)
# ADMIN_SECRET=

# Optional backup: comma-separated emails that always get free Professional (unlimited)
# Survives Render disk resets. Prefer /admin Free access UI for day-to-day grants.
# COMPLIMENTARY_EMAILS=friend@example.com,employee@example.com

# Permanent Free-access email list (survives Render redeploys) — recommended
# 1) Create a private GitHub Gist with one file named: complimentary-emails.json
#    Contents: {"entries":[]}
# 2) Copy the Gist ID from the URL: https://gist.github.com/you/GIST_ID_HERE
# 3) Create a GitHub token (classic) with "gist" scope
# 4) Set both on Render → Environment, then redeploy
# COMPLIMENTARY_GIST_ID=your_gist_id
# GITHUB_TOKEN=ghp_xxxxxxxx

# Signup email OTP (Resend). Without this, the OTP is shown on the verify page (dev mode).
# Get a free key at https://resend.com — verify a domain (or use onboarding@resend.dev for tests to your own signup email).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=JoBPilot.AI <onboarding@resend.dev>

# Google Sign-In (same Client ID on server + Vite)
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Comma-separated frontend origins (Vercel URL included automatically)
ALLOWED_ORIGINS=https://enhancer-v2.vercel.app,https://your-domain.com

# Frontend (Vercel) — point to your deployed API
# VITE_API_BASE=https://your-api.onrender.com/api/enhancer
# VITE_AUTH_API_BASE=https://your-api.onrender.com/api/auth
