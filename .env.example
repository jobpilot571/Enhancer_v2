# AI Provider order (comma-separated). System tries each in order until one succeeds.
AI_PROVIDER_ORDER=openai,groq,claude,gemini,ollama

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# Groq (OpenAI-compatible)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (cloud/turbo key, OpenAI-compatible)
OLLAMA_API_KEY=your_ollama_key_here
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gpt-oss:20b

PORT=3001

# Comma-separated frontend origins (Vercel URL included automatically)
ALLOWED_ORIGINS=https://enhancer-v2.vercel.app,https://your-domain.com

# Frontend (Vercel) — point to your deployed API
# VITE_API_BASE=https://your-api.onrender.com/api/enhancer
